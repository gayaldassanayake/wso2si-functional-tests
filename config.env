# =============================================================================
# WSO2 Streaming Integrator 4.3.2 Test Suite Configuration
# =============================================================================
# Set SI_HOME to your installed SI binary directory before running tests:
#   export SI_HOME=/path/to/wso2si-4.3.2
# Or pass inline:
#   SI_HOME=/path/to/wso2si-4.3.2 ./run_all_tests.sh

SI_HOME="${SI_HOME:-/path/to/wso2si-4.3.2}"

# Derived paths (override if your SI layout differs)
SI_SIDDHI_DIR="${SI_HOME}/wso2/server/deployment/siddhi-files"
SI_LOG="${SI_HOME}/wso2/server/logs/carbon.log"

# SI server ports (per deployment.yaml defaults)
SI_HTTP_PORT=9090
SI_STORE_API_PORT=7070
SI_STORE_API_USER="admin"
SI_STORE_API_PASS="admin"

# Docker Compose infrastructure
KAFKA_BOOTSTRAP="localhost:9092"
KAFKA_CONTAINER="si-test-kafka"
MYSQL_HOST="localhost"
MYSQL_PORT=3306
MYSQL_USER="sitest"
MYSQL_PASS="sitest123"
MYSQL_DB="si_test_db"
MYSQL_CONTAINER="si-test-mysql"

# Test tuning
DEPLOY_WAIT_SECONDS=8        # seconds to wait after copying a Siddhi app
LOG_TAIL_LINES=500           # lines of log to scan for assertions
PATTERN_WAIT_SECONDS=5       # seconds to wait for patterns to fire
WINDOW_WAIT_SECONDS=12       # seconds to wait for time windows to expire

# File source test file (must be accessible by SI server process)
FILE_SOURCE_PATH="/tmp/si-test-sales.csv"

# HTTP source ports (each app gets a unique port to allow concurrent deployment)
PORT_TC01=8099
PORT_TC02=8100
PORT_TC03=8101
PORT_TC04=8102
PORT_TC05=8103
PORT_TC06=8104
PORT_TC07=8105
# TC08 uses Kafka (no HTTP port)
PORT_TC09=8106
PORT_TC10=8107
# TC11 uses CDC (no HTTP port for source)
# TC12 uses File source (no HTTP port)
PORT_TC13=8108
PORT_TC14=8109
PORT_TC15=8110
PORT_TC16=8111
PORT_TC17=8112
PORT_TC18=8113
